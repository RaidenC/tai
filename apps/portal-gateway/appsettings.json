{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "ApiRoute": {
        "ClusterId": "IdentityCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "X-Forwarded": "Append" }
        ]
      },
      "AccountRoute": {
        "ClusterId": "IdentityCluster",
        "Match": {
          "Path": "/Account/{**catch-all}"
        }
      },
      "IdentityRoute": {
        "ClusterId": "IdentityCluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" },
          { "X-Forwarded": "Append" },
          { "RequestHeader": "X-Tenant-Host", "Set": "{Host}" }
        ]
      },
      "OidcDiscoveryRoute": {
        "ClusterId": "IdentityCluster",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "OidcConnectRoute": {
        "ClusterId": "IdentityCluster",
        "RateLimiterPolicy": "token-bucket",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "IdentityCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://localhost:5031/"
          }
        }
      }
    }
  }
}
