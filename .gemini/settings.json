{
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "format-csharp",
            "type": "command",
            "command": ".gemini/hooks/format-csharp.sh",
            "description": "Runs dotnet format whitespace after every C# file write or edit"
          }
        ]
      }
    ]
  }
}